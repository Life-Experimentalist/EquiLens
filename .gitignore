# EquiLens .gitignore

# Python bytecode and cache
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.ruff_cache/

# Build artifacts
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
env/
ENV/
env.bak/
venv.bak/
.env
.venv/
.venv-*/

# UV cache
.uv-cache/

# Runtime outputs (generated at runtime, not committed)
results/
logs/
*.log

# Corpus data (large generated datasets)
src/Phase1_CorpusGenerator/corpus/

# Backup and temp files
*.bak
*.backup
*.old
*.tmp
*.temp
tmp/
temp/

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
.devcontainer/
.claude/

# Test/coverage artifacts
.pytest_cache/
.coverage
coverage.xml
*.cover
.hypothesis/
htmlcov/

# Node modules (if any)
node_modules/

# Archives
*.tar
*.tar.gz
*.zip
*.rar

# Misc stale patterns
audit_llm/
.container-welcome

# Graphify
graphify-out/cache/*
